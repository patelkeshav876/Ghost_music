# ══════════════════════════════════════════════════════════
#  GhostMusic Bot — Environment Variables
#  Copy to .env and fill in your values.
#  NEVER commit .env to git.
# ══════════════════════════════════════════════════════════

# ── REQUIRED ─────────────────────────────────────────────

# Get from https://my.telegram.org/apps
API_ID=12345678
API_HASH=your_api_hash_here

# Get from @BotFather
BOT_TOKEN=123456789:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdef

# Pyrogram session string for the ASSISTANT (user) account
# Generate with: python -c "from pyrogram import Client; Client(':memory:', api_id=..., api_hash='...').run()"
# Or use: https://t.me/StringFatherBot
SESSION_STRING=your_session_string_here

# MongoDB Atlas or self-hosted URI
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/ghostmusic?retryWrites=true&w=majority
DB_NAME=ghostmusic

# Your Telegram user ID (get from @userinfobot)
OWNER_ID=123456789

# ── OPTIONAL ──────────────────────────────────────────────

# Comma-separated Telegram user IDs with sudo access
SUDO_USERS=123456789,987654321

# Spotify integration (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_SECRET=

# Genius API for lyrics (https://genius.com/api-clients)
GENIUS_TOKEN=

# Last.fm API key (optional, for music metadata)
LASTFM_KEY=

# ── BOT BEHAVIOUR ─────────────────────────────────────────

# audio quality: high | medium | low
STREAM_QUALITY=high

# default volume (1-200)
DEFAULT_VOLUME=100

# max tracks in queue per chat
MAX_QUEUE_SIZE=50

# max tracks per playlist
MAX_PLAYLIST_SIZE=100

# seconds idle before bot leaves voice chat
AUTO_LEAVE_DELAY=60

# auto-delete bot messages after N seconds (0 = disabled)
AUTO_CLEAN_MSGS=true

# command prefix character
COMMAND_PREFIX=/

# ── ADMIN / LOGGING ───────────────────────────────────────

LOG_LEVEL=INFO

# Telegram channel ID for error logs (optional, e.g. -1001234567890)
LOG_CHANNEL=-1002293022514

# ── STATS API (for web dashboard) ─────────────────────────

# Port for the HTTP stats API server
STATS_PORT=8080

# Secret header value — set a strong random string
STATS_SECRET=change_this_to_a_strong_random_secret
